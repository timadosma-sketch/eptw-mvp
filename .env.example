# ============================================================
# ePTW Platform — Environment Variables Template
# ============================================================
# Copy this file to .env.local for local development.
# NEVER commit .env.local or .env.production to git.
#
# Variable naming rules:
#   NEXT_PUBLIC_*  → exposed to browser (safe for non-secrets)
#   All others     → server-side only (never sent to client)
# ============================================================

# ------------------------------------------------------------
# App Identity
# ------------------------------------------------------------
NEXT_PUBLIC_APP_NAME="ePTW Platform"
NEXT_PUBLIC_APP_VERSION="1.0.0"
NEXT_PUBLIC_FACILITY_NAME="Al-Noor Oil & Gas Refinery"
NEXT_PUBLIC_FACILITY_LOCATION="Atyrau, Kazakhstan"

# ------------------------------------------------------------
# Environment tag (development | staging | production)
# ------------------------------------------------------------
NEXT_PUBLIC_ENV="development"

# ------------------------------------------------------------
# API Backend (when backend is wired up)
# ------------------------------------------------------------
# NEXT_PUBLIC_API_URL="https://api.eptw.yourdomain.com"
# API_SECRET_KEY="replace_with_strong_secret"

# ------------------------------------------------------------
# Authentication (when auth is added — e.g. NextAuth)
# ------------------------------------------------------------
# NEXTAUTH_URL="https://eptw.yourdomain.com"
# NEXTAUTH_SECRET="replace_with_openssl_rand_base64_32"

# OAuth providers (example):
# AZURE_AD_CLIENT_ID=""
# AZURE_AD_CLIENT_SECRET=""
# AZURE_AD_TENANT_ID=""

# ------------------------------------------------------------
# Database (when Prisma / backend DB is added)
# ------------------------------------------------------------
# DATABASE_URL="postgresql://user:password@host:5432/eptw_prod?sslmode=require"

# ------------------------------------------------------------
# Monitoring & Error Tracking
# ------------------------------------------------------------
# NEXT_PUBLIC_SENTRY_DSN=""
# SENTRY_AUTH_TOKEN=""
# NEXT_PUBLIC_POSTHOG_KEY=""

# ------------------------------------------------------------
# Feature Flags (optional, useful for staged rollouts)
# ------------------------------------------------------------
# NEXT_PUBLIC_FF_REAL_API="false"
# NEXT_PUBLIC_FF_AUTH_ENABLED="false"
